// LeanCloud 配置文件
// 复制此文件为 config.js 并填入你的 LeanCloud 项目信息

// 如何获取这些信息：
// 1. 访问 https://console.leancloud.cn/ 并注册账号（国内网站，无需翻墙）
// 2. 点击 "创建应用"，选择 "开发版"（免费）
// 3. 进入应用设置 -> 应用凭证
// 4. 复制 AppID、AppKey 和服务器地址（可选）

window.leancloudConfig = {
    // 你的 LeanCloud App ID
    appId: 'YOUR_LEANCLOUD_APP_ID',
    
    // 你的 LeanCloud App Key
    appKey: 'YOUR_LEANCLOUD_APP_KEY',
    
    // 服务器地址（可选，国内节点通常不需要）
    serverURL: 'YOUR_SERVER_URL'  // 例如：https://your-app-id.leancloud.cn
};

// 如果不配置 LeanCloud，系统将使用本地存储（localStorage）
// 注意：本地存储的数据仅保存在当前浏览器中，其他设备无法访问